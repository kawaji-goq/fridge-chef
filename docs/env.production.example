# 本番用 .env サンプル
# 実際の .env は別途サーバ上で作成し、機密値は実値に置換

APP_NAME=fridge-chef
APP_ENV=production
APP_KEY=                         # php artisan key:generate で生成
APP_DEBUG=false
APP_URL=https://fridge-chef.bug-sandbox.com

APP_LOCALE=ja
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ja_JP

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# DB（Docker 内部の mysql コンテナ）
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=fridge_chef
DB_USERNAME=fridge
DB_PASSWORD=*****CHANGE_ME*****

# Redis（Docker 内部）
REDIS_HOST=redis
REDIS_PORT=6379

# Session / Cookie（HTTPS 配下）
SESSION_DRIVER=database
SESSION_LIFETIME=525600           # 1 年（匿名ユーザー継続のため）
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_DOMAIN=fridge-chef.bug-sandbox.com

# Queue / Cache
QUEUE_CONNECTION=database
CACHE_STORE=database

# Sail 設定（本番でもイメージ流用するため）
# 注: docker compose はインラインコメントを認識しないため、値の右にコメントを書かないこと
# APP_PORT: ホスト側 127.0.0.1:8090 → コンテナ 80
APP_PORT=8090
# FORWARD_DB_PORT / FORWARD_REDIS_PORT は本番では公開しないので空のまま
FORWARD_DB_PORT=
FORWARD_REDIS_PORT=
WWWUSER=1000
WWWGROUP=1000

# AWS / Bedrock（IAM ユーザー fridge-chef-app のキー）
AWS_ACCESS_KEY_ID=*****CHANGE_ME*****
AWS_SECRET_ACCESS_KEY=*****CHANGE_ME*****
AWS_DEFAULT_REGION=ap-northeast-1

BEDROCK_REGION=ap-northeast-1
BEDROCK_MODEL_ID=jp.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_DRIVER=real

# 楽天レシピ API（無料登録、Rakuten Developers）
# applicationId は UUID 形式、accessKey は "pk_..." 形式
RAKUTEN_APP_ID=*****CHANGE_ME*****
RAKUTEN_ACCESS_KEY=*****CHANGE_ME*****
